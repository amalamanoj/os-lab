#include <stdio.h>
#define MAX 20
#define Q 3

int n,pid[MAX],at[MAX],bt[MAX],pr[MAX],ct[MAX],tat[MAX],wt[MAX],rt[MAX];

int main(){
    int i,j,t,count,done[MAX]; float avg,fcfs,sjf,pri,rr;
    printf("Enter the number of processes: "); scanf("%d",&n);
    for(i=0;i<n;i++){
        pid[i]=i+1;
        printf("\nProcess %d\n",pid[i]);
        printf("Arrival Time: "); scanf("%d",&at[i]);
        printf("Burst Time: "); scanf("%d",&bt[i]);
        printf("Priority: "); scanf("%d",&pr[i]);
    }
    for(i=0;i<n-1;i++) for(j=i+1;j<n;j++) if(at[i]>at[j]){
        int t0; 
        t0=at[i]; 
        at[i]=at[j];
        at[j]=t0;
        t0=bt[i]; 
        bt[i]=bt[j];
        bt[j]=t0;
        t0=pr[i];
        pr[i]=pr[j]; 
        pr[j]=t0;
        t0=pid[i]; 
        pid[i]=pid[j];
        pid[j]=t0;
    }
    void print(){for(i=0;i<n;i++) printf("%d\t%d\t%d\t%d\t%d\t%d\n",pid[i],at[i],bt[i],ct[i],tat[i],wt[i]);}

    t=0; avg=0; printf("\n===== FCFS Scheduling =====\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    for(i=0;i<n;i++){
        if(t<at[i]) t=at[i];
        ct[i]=t+bt[i];
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];
        avg+=wt[i]; 
        t=ct[i];}
    print();
    fcfs=avg/n;
    printf("Average Waiting Time (FCFS) = %.2f\n",fcfs);

    for(i=0;i<n;i++) done[i]=0;
    t=0;
    avg=0;
    count=0;
    printf("\n===== SJF (Non-Preemptive) =====\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    while(count<n){
        int idx=-1,min=9999;
        for(i=0;i<n;i++) 
        if(!done[i]&&at[i]<=t&&bt[i]<min)
        min=bt[i],idx=i;
        idx==-1?
        t++ :
        (ct[idx]=t+bt[idx],tat[idx]=ct[idx]-at[idx],wt[idx]=tat[idx]-bt[idx],avg+=wt[idx],t=ct[idx],done[idx]=1,count++);
    }
    print(); 
    sjf=avg/n; printf("Average Waiting Time (SJF) = %.2f\n",sjf);

    for(i=0;i<n;i++) done[i]=0;
    t=0; 
    avg=0; 
    count=0;
    printf("\n===== Priority (Non-Preemptive) =====\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    while(count<n){
        int idx=-1,high=-1;
        for(i=0;i<n;i++)
        if(!done[i]&&at[i]<=t&&pr[i]>high) high=pr[i],idx=i;
        idx==-1?
        t++ : 
        (ct[idx]=t+bt[idx],tat[idx]=ct[idx]-at[idx],wt[idx]=tat[idx]-bt[idx],avg+=wt[idx],t=ct[idx],done[idx]=1,count++);
    }
    print(); 
    pri=avg/n;
    printf("Average Waiting Time (Priority) = %.2f\n",pri);

    for(i=0;i<n;i++) rt[i]=bt[i];
    t=0;
    count=0;
    avg=0;
    printf("\n===== Round Robin (Quantum = 3) =====\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    while(count<n){
        int idle=1;
        for(i=0;i<n;i++) 
        if(rt[i]>0 && at[i]<=t){
            idle=0;
            rt[i]>Q? 
            (t+=Q,rt[i]-=Q) : 
            (t+=rt[i],ct[i]=t,tat[i]=ct[i]-at[i],wt[i]=tat[i]-bt[i],avg+=wt[i],rt[i]=0,count++);
        }
        if(idle) t++;
    }
    print();
    rr=avg/n; printf("Average Waiting Time (RR) = %.2f\n",rr);

    float min=fcfs;
    char *alg="FCFS";
    if(sjf<min)
    min=sjf,alg="SJF (Non-Preemptive)";
    if(pri<min) 
    min=pri,alg="Priority (Non-Preemptive)";
    if(rr<min)
    min=rr,alg="Round Robin (Q=3)";
    printf("\nAlgorithm with Minimum Average Waiting Time: %s (%.2f)\n",alg,min);
}
