   #include <stdio.h>

int search(int frames[], int f, int page) {
    for (int i = 0; i < f; i++)
        if (frames[i] == page) return 1;
    return 0;}

int main() {
    int n, f, pages[100], frames[10];
    printf("Enter length of reference string: ");
    scanf("%d", &n);
    printf("Enter number of frames (1-7): ");
    scanf("%d", &f);
    printf("Enter %d page numbers (0-9):\n", n);
    for (int i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    int fifo = 0, lru = 0, opt = 0;
    for (int i = 0; i < f; i++) frames[i] = -1;
    int idx = 0;
    for (int i = 0; i < n; i++) {
        if (!search(frames, f, pages[i])) {
            frames[idx] = pages[i];
            idx = (idx + 1) % f;
            fifo++;} }

    int time[10] = {0}, count = 0;
    for (int i = 0; i < f; i++) frames[i] = -1;
    for (int i = 0; i < n; i++) {
        if (search(frames, f, pages[i])) {
            for (int j = 0; j < f; j++)
                if (frames[j] == pages[i])
                    time[j] = ++count;
        } else {
            int min = 0;
            for (int j = 1; j < f; j++)
                if (time[j] < time[min]) min = j;

            frames[min] = pages[i];
            time[min] = ++count;
            lru++;}}

    for (int i = 0; i < f; i++) frames[i] = -1;
    for (int i = 0; i < n; i++) {
        if (!search(frames, f, pages[i])) {
            int pos = 0, farthest = -1;
            for (int j = 0; j < f; j++) {
                int k;
                for (k = i + 1; k < n; k++)
                    if (frames[j] == pages[k]) break;
                if (k == n) { pos = j; break; }
                if (k > farthest) {
                    farthest = k;
                    pos = j;}}
            frames[pos] = pages[i];
            opt++;}}

    printf("FIFO Page Faults = %d\n", fifo);
    printf("LRU Page Faults = %d\n", lru);
    printf("Optimal Page Faults = %d\n", opt);

    return 0;
}             
