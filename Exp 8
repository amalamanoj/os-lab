#include <stdio.h>

int main() {
    int n=5, m=3, i, j, k, count=0;

    int alloc[5][3] = {{1,0,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}};
    int max[5][3]   = {{7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}};
    int avail[3]    = {3,5,2}; // adjusted to be safe

    int need[5][3], finish[5]={0}, safeSeq[5];

    // Calculate Need
    for(i=0;i<n;i++)
        for(j=0;j<m;j++)
            need[i][j] = max[i][j] - alloc[i][j];

    while(count<n){
        int found=0;
        for(i=0;i<n;i++){
            if(!finish[i]){
                int possible=1;
                for(j=0;j<m;j++){
                    if(need[i][j]>avail[j]){
                        possible=0; break;
                    }
                }
                if(possible){
                    for(k=0;k<m;k++) avail[k]+=alloc[i][k];
                    safeSeq[count++]=i;
                    finish[i]=1;
                    found=1;
                }
            }
        }
        if(!found){
            printf("System is NOT in safe state\n");
            return 0;
        }
    }

    printf("Safe sequence: ");
    for(i=0;i<n;i++) printf("P%d ", safeSeq[i]);
    return 0;
}
